entity:ScaleTo(1.5)

	if entity:IsA("Model") then
		local primary = entity.PrimaryPart or entity:FindFirstChildWhichIsA("BasePart", true)
		if primary then
			entity.PrimaryPart = primary
			primary.CFrame = cf -- ðŸ‘ˆ QUAN TRá»ŒNG
		end
	elseif entity:IsA("BasePart") then
		entity.CFrame = cf
	end
end

local function getSpawnNode(room)
	for _, obj in ipairs(room:GetDescendants()) do
		if obj:IsA("BasePart")
			and obj.Name == "Node"
			and obj.Parent
			and obj.Parent:IsA("Folder")
			and obj.Parent.Name == "EntityNodes" then

			return obj
		end
	end

	return nil
end

