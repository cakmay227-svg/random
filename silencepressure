local function applyRoomEffects(room)
    if not room then return end
    
    local function playBreakSound(part)
    if not part then return end

    local sound = Instance.new("Sound")  
    sound.SoundId = BREAK_SOUND_ID
    sound.Volume = 1  
    sound.RollOffMaxDistance = 80  
    sound.Parent = part  
    sound:Play()  

    sound.Ended:Connect(function()  
        sound:Destroy()  
    end)
end

    local endTime = os.clock() + 0.2

    for _, obj in ipairs(room:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name == "Sign" then
            for _, gui in ipairs(obj:GetChildren()) do
                if gui:IsA("SurfaceGui") then
                    for _, label in ipairs(gui:GetDescendants()) do
                        if label:IsA("TextLabel") and not label:GetAttribute("Darkened") then
                            label:SetAttribute("Darkened", true)

                            local originalColor = label.TextColor3
                            label.TextColor3 = Color3.new(
                                originalColor.R * 0.15,
                                originalColor.G * 0.15,
                                originalColor.B * 0.15
                            )
                        end
                    end
                end
            end
        end

        if not obj:GetAttribute("Broken") then
            local isLight = obj:IsA("Light") and obj.Parent and obj.Parent:IsA("BasePart")
            local isNeonPart = obj:IsA("BasePart") and obj.Material == Enum.Material.Neon

            if isLight or isNeonPart then
                obj:SetAttribute("Broken", true)

                if isLight and obj.Enabled then
                    task.spawn(function()
                        while os.clock() < endTime do
                            obj.Enabled = not obj.Enabled
                            
                            task.spawn(function() 
                            playBreakSound(obj)
                            end) 
                            
                            task.wait(math.random(3, 10) / 100)
                        end
                        obj.Enabled = false                                                                                                        
                    end)
                end

                if isNeonPart then
                    obj.Material = Enum.Material.SmoothPlastic
                end
            end
        end
    end
end

