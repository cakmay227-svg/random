local function initializeBypassedShaker(originPart)
	local playerCamera = workspace.CurrentCamera
	if not playerCamera then
		return nil
	end

	local currentCFrame = playerCamera.CFrame

	local function cameraCallback(shakeCFrame)
		playerCamera.CFrame = currentCFrame * shakeCFrame
	end

	local shaker = {
		_running = true,
		_renderName = "FrostyCameraShake_" .. tostring(math.random(1,9999999)),
		_renderPriority = Enum.RenderPriority.Camera.Value + 1,
		_camShakeInstances = {},
		_removeInstances = {},
		_callback = cameraCallback
	}

	RunService:BindToRenderStep(shaker._renderName, shaker._renderPriority, function(dt)

		currentCFrame = playerCamera.CFrame

		if not originPart or not originPart.Parent then
			RunService:UnbindFromRenderStep(shaker._renderName)
			return
		end

		if not PlayerInRange(originPart, CameraShakeRange) then
			return
		end

		local posAccumulator = Vector3.zero
		local rotAccumulator = Vector3.zero

		for i = 1,#shaker._camShakeInstances do

			local inst = shaker._camShakeInstances[i]

			if inst.currentFadeTime <= 0 and not inst.sustain then
				table.insert(shaker._removeInstances,i)
			else

				local deltaTick = inst.tick
				local fadeTime = inst.currentFadeTime

				local noise = Vector3.new(
					math.noise(deltaTick,0)*0.5,
					math.noise(0,deltaTick)*0.5,
					math.noise(deltaTick,deltaTick)*0.5
				)

				if inst.fadeInDuration>0 and inst.sustain then
					if fadeTime<1 then
						fadeTime += dt/inst.fadeInDuration
					end
				end

				if not inst.sustain then
					fadeTime -= dt/inst.fadeOutDuration
				end

				if inst.sustain then
					inst.tick += dt*inst.Roughness*inst.roughMod
				else
					inst.tick += dt*inst.Roughness*inst.roughMod*fadeTime
				end

				inst.currentFadeTime = math.clamp(fadeTime,0,1)

				local shake = noise*inst.Magnitude*inst.magnMod*fadeTime

				posAccumulator += shake*inst.PositionInfluence
				rotAccumulator += shake*inst.RotationInfluence
			end
		end

		for i=#shaker._removeInstances,1,-1 do
			table.remove(shaker._camShakeInstances,shaker._removeInstances[i])
			shaker._removeInstances[i]=nil
		end

		local cf =
			CFrame.new(posAccumulator)
			* CFrame.Angles(0,math.rad(rotAccumulator.Y),0)
			* CFrame.Angles(math.rad(rotAccumulator.X),0,math.rad(rotAccumulator.Z))

		shaker._callback(cf)

	end)

	return shaker
end

local function StartCameraShake(originPart)

	local shaker = initializeBypassedShaker(originPart)

	if not shaker then
		return
	end

	table.insert(shaker._camShakeInstances,{
		Magnitude = 0.4,
		Roughness = 20,
		PositionInfluence = Vector3.new(0,0.15,0),
		RotationInfluence = Vector3.new(1.25,0,4),

		roughMod = ShakeConfig.SpeedMultiplier,
		magnMod = ShakeConfig.Intensity,

		fadeOutDuration = 0.5,
		fadeInDuration = 2,

		sustain = true,
		currentFadeTime = 0,

		tick = Random.new():NextNumber(-100,100)
	})

	return shaker
end

