	end

	FlickerEnabled = true

	task.spawn(function()
		while FlickerEnabled do
			local connections = getConnectionsFromSignal(urSpecialEffects.OnClientEvent)

			if connections and #connections > 0 then
				local validLights = {}

				for _, v in ipairs(workspace:GetDescendants()) do
					if v.Name == "Lights" then
						for _, lightPart in ipairs(v:GetChildren()) do
							if lightPart.Name ~= "OceanNeon"
