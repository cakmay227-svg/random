local function getConnectionsFromSignal(signal)
    if getconnections then return getconnections(signal) end
    if get_signal_cons then return get_signal_cons(signal) end
    
    local success, result = pcall(function() return signal:GetConnections() end)
    if success then return result end
    
    local success2, result2 = pcall(function() return signal:getconnections() end)
    if success2 then return result2 end
    
    return nil
end

