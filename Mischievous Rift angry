local function allowedParticles(name)
	return name == "Explosion"
		or name == "RiftLines"
		or name == "RiftLines2"
end

local rolling = false

local function startRolling(model)
	rolling = true

	task.spawn(function()
		local angles = {0, 90, 180, 270}
		local i = 1

		while rolling and model and model.Parent do
			local cf = model:GetPivot()

			model:PivotTo(
				CFrame.new(cf.Position) * CFrame.Angles(0, math.rad(angles[i]), 0)
			)

			i = (i % 4) + 1
			task.wait(0.05)
		end
	end)
end

local function stopRolling()
	rolling = false
end

