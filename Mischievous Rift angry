local function playParticlesOnce(folder)
	if not folder then return 0 end

	local allowed = {
		Explosion = true,
		RiftLines = true,
		RiftLines2 = true
	}

	local longest = 0

	for _, v in ipairs(folder:GetDescendants()) do
		if v:IsA("ParticleEmitter") and allowed[v.Name] then

			v.Enabled = false

			local amount = v:GetAttribute("EmitCount") or 20
			v:Emit(amount)

			local t = v.Lifetime.Max + (v:GetAttribute("EmitDelay") or 0)
			if t > longest then
				longest = t
			end
		end
	end

	return longest
end

