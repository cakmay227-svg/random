local function glitchText()
	if not warningLabel then return end

	task.spawn(function()
		while warningLabel and warningLabel.Parent do
			local base = "!!! ENTITY DETECTED !!!"

			-- glitch random ký t
			local glitched = ""
			for i = 1, #base do
				local c = base:sub(i,i)
				if math.random(1, 6) == 1 then
					c = string.char(math.random(33, 126))
				end
				glitched ..= c
			end

			warningLabel.Text = glitched
			warningLabel.Rotation = math.random(-3, 3)
			warningLabel.TextTransparency = math.random(0, 2) * 0.1

			task.wait(1)
		end
	end)
end

