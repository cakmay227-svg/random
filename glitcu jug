--  SHIFT ANY COLOR  PURPLE (gi  sáng + saturation)
local function shiftToPurple(color)
	local h, s, v = color:ToHSV()

	return Color3.fromHSV(
		270 / 360, -- tím
		s,
		v -- gi  sáng
	)
end

-- xá»­ lÃ½ ColorSequence (Particle / Trail / Beam / Gradient)
local function shiftSequence(seq)
	local newKeypoints = {}

	for _, k in ipairs(seq.Keypoints) do
		table.insert(
			newKeypoints,
			ColorSequenceKeypoint.new(
				k.Time,
				shiftToPurple(k.Value)
			)
		)
	end

	return ColorSequence.new(newKeypoints)
end

-- main processor
local function process(inst)

	-- BasePart
	if inst:IsA("BasePart") then
		inst.Color = shiftToPurple(inst.Color)
	end

	-- VFX
	if inst:IsA("ParticleEmitter")
	or inst:IsA("Trail")
	or inst:IsA("Beam") then
		inst.Color = shiftSequence(inst.Color)
	end

	-- Light
	if inst:IsA("PointLight")
	or inst:IsA("SpotLight")
	or inst:IsA("SurfaceLight") then
		inst.Color = shiftToPurple(inst.Color)
	end

	-- UIGradient
	if inst:IsA("UIGradient") then
		inst.Color = shiftSequence(inst.Color)
	end
end

