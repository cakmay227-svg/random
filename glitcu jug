local function stopWarningSystem()
	if warningConn then
		warningConn:Disconnect()
		warningConn = nil
	end

	if warningGui then
		warningGui:Destroy()
		warningGui = nil
		warningLabel = nil
	end

	for _, s in ipairs(warningSounds) do
		if s then
			s:Stop()
			s:Destroy()
		end
	end

	warningSounds = {}

	if warningGui then
		warningGui:SetAttribute("Active", false)
	end
end

local function startEntityLoop()
	if warningConn then return end

	warningConn = RunService.Heartbeat:Connect(function()
		local entityType = nil

		for _, obj in ipairs(Workspace:GetDescendants()) do
			if obj:IsA("Model") then
				if obj.Name == "RushMoving" then
					entityType = "RUSH"
					break
				elseif obj.Name == "AmbushMoving" then
					entityType = "AMBUSH"
					break
				end
			end
		end

		if entityType then
			createWarningUI()

			-- set text theo entity
			if entityType == "RUSH" then
				warningLabel.Text = "RUSH IS COMING"
			elseif entityType == "AMBUSH" then
				warningLabel.Text = "AMBUSH IS COMING"
			end

			-- ch chy glitch + sound 1 ln
			if not warningGui:GetAttribute("Active") then
				warningGui:SetAttribute("Active", true)
				glitchText()
				playWarningSounds()
			end

		else
			-- cleanup khi không còn entity
			if warningGui then
				warningGui:Destroy()
				warningGui = nil
				warningLabel = nil
			end

			for _, s in ipairs(warningSounds) do
				if s then s:Destroy() end
			end
			warningSounds = {}
		end
	end)
end

