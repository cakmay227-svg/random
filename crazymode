task.spawn(function()
	while gui.Parent do
		TweenService:Create(bg, TweenInfo.new(0.2), {
			BackgroundColor3 = Color3.fromRGB(120, 0, 0)
		}):Play()
		task.wait(0.2)

		TweenService:Create(bg, TweenInfo.new(0.2), {
			BackgroundColor3 = Color3.new(0, 0, 0)
		}):Play()
		task.wait(0.2)
	end
