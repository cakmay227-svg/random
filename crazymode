local function killPlayer()
	local char = player.Character
	if not char then return end

	local hum = char:FindFirstChildOfClass("Humanoid")
	if hum then
		hum.Health = 0
	end

	deathHook()
end

local function getChar()
	local char = player.Character or player.CharacterAdded:Wait()
	local hrp = char:WaitForChild("HumanoidRootPart")
	return char, hrp
end

local function isPlayerInRoom(room, pos)
	local cf, size = room:GetBoundingBox()

	local relative = cf:PointToObjectSpace(pos)
	local half = size / 2

	return math.abs(relative.X) <= half.X
		and math.abs(relative.Y) <= half.Y
		and math.abs(relative.Z) <= half.Z
end

local function getCurrentRoom()
	local rooms = Workspace:WaitForChild("CurrentRooms"):GetChildren()
	local _, hrp = getChar()

	for _, room in ipairs(rooms) do
		if isPlayerInRoom(room, hrp.Position) then
			return room
		end
	end

	return nil
end

local function getPoints(room)
	local entrance = room:FindFirstChild("RoomEntrance", true)
	local exit = room:FindFirstChild("RoomExit", true)

	if entrance and exit then
		local p1 = entrance:IsA("BasePart") and entrance.Position or entrance:GetPivot().Position
		local p2 = exit:IsA("BasePart") and exit.Position or exit:GetPivot().Position
		return p1, p2
	end

	return nil, nil
end

