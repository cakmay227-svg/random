local function getLine(err)
	return tonumber(tostring(err):match(":(%d+):"))
end

local function context(src, line)
	local lines = {}
	for l in (src or ""):gmatch("[^\n]+") do
		table.insert(lines, l)
	end

	local s = math.max(1, line - 3)
	local e = math.min(#lines, line + 3)

	local out = {}
	for i = s, e do
		local mark = (i == line) and "👉 " or "   "
		table.insert(out, mark .. i .. " | " .. (lines[i] or ""))
	end

	return table.concat(out, "\n")
end

-- ===== HINT ENGINE =====
local function hint(err, src, line)
	local e = tostring(err):lower()

	-- =========================
	-- 1. SYNTAX CORE (Lua grammar)
	-- =========================
	if e:find("expected") then

		if e:find("then") then
			return "Syntax: thiếu 'then' trong if statement → if ... then end"
		end

		if e:find("end") then
			return "Block mismatch: thiếu 'end' (if/for/function/while chưa đóng)"
		end

		if e:find("%)") then
			return "Bracket error: thiếu hoặc dư dấu ')'"
		end

		if e:find("symbol") then
			return "Syntax broken: có ký tự sai vị trí hoặc thiếu toán tử"
		end

		return "Lua syntax error: kiểm tra cấu trúc (if/then/end, (), commas)"
	end

	-- =========================
	-- 2. RUNTIME NIL / OBJECT
	-- =========================
	if e:find("attempt to index") then
		return "Runtime nil: đang index vào nil object (chưa tạo / chưa load / sai path)"
	end

	if e:find("attempt to call") then
		return "Type error: gọi non-function value (có thể string/table/nil)"
	end

	if e:find("attempt to perform") then
		return "Math/type mismatch: phép toán trên kiểu dữ liệu không hợp lệ"
	end

	-- =========================
	-- 3. VARIABLE / SCOPE
	-- =========================
	if e:find("nil value") then
		return "Nil reference: biến chưa assign hoặc bị scope ngoài function"
	end

	if e:find("global") then
		return "Scope issue: biến global/local conflict hoặc chưa khai báo đúng"
	end

	-- =========================
	-- 4. FUNCTION / CALL SYSTEM
	-- =========================
	if e:find("bad argument") then
		return "Function argument sai kiểu hoặc sai số lượng tham số"
	end

	if e:find("not a function") then
		return "Value overwrite: biến bị ghi đè thành non-function type"
	end

	-- =========================
	-- 5. TABLE / DATA STRUCTURE
	-- =========================
	if e:find("table") then
		return "Table error: index sai key hoặc table chưa init"
	end

	if e:find("index") and e:find("nil") then
		return "Table nil access: key không tồn tại hoặc bảng chưa tạo"
	end

	-- =========================
	-- 6. ROBLOX SPECIFIC
	-- =========================
	if e:find("waitforchild") then
		return "Roblox timing issue: object chưa replicate → cần WaitForChild"
	end

	if e:find("attempt to index") and e:find("workspace") then
	return "Workspace index error: chỉ lỗi khi path con bị nil, không phải workspace itself"
end

if e:find("workspace") and not e:find("attempt") then
	return "Workspace luôn tồn tại trong Roblox → đây là false positive từ detector"
end

if e:find("players") and not e:find("attempt") then
	return "Players service luôn tồn tại → lỗi này từ heuristic, không phải runtime"
end

	-- =========================
	-- 7. HTTP / LOAD / EXECUTION
	-- =========================
	if e:find("http") then
		return "HTTP error: link sai / không raw / bị chặn request"
	end

	if e:find("loadstring") then
		return "Compile failure: script lỗi syntax trước khi runtime"
	end

	-- =========================
	-- 8. CROSS-LINE LOGIC (ADVANCED)
	-- =========================
	if src and line then
		local lines = {}
		for l in src:gmatch("[^\n]+") do
			table.insert(lines, l)
		end

		local prev = lines[line - 1]
		local curr = lines[line]

		if prev and curr then

			-- print \n "text"
			if prev:match("print%s*$") and curr:match("^%s*['\"]") then
				return "Broken call: function + argument split across lines (print misuse)"
			end

			-- local a \n = 5
			if prev:match("local%s+%a+%s*$") and curr:match("^%s*=") then
				return "Assignment split: local declaration bị tách dòng sai cú pháp"
			end

			-- return \n value
			if prev:match("return%s*$") then
				return "Return split error: return bị tách dòng → mất expression binding"
			end

			-- function split
			if prev:match("function%s*%w*%s*$") then
				return "Function header broken: function bị tách dòng hoặc thiếu name/()"
			end
		end
	end

	-- =========================
	-- 9. LOGIC / DESIGN ERRORS
	-- =========================
	if e:find("infinite") then
		return "Logic risk: có thể infinite loop hoặc recursion không dừng"
	end

	if e:find("loop") then
		return "Loop issue: for/while có thể sai condition hoặc thiếu break"
	end

	-- =========================
	-- 10. GENERIC INTELLIGENT FALLBACK
	-- =========================
	local fallback = {
		"Debug tip: lỗi thường nằm 1–3 dòng phía trên vị trí crash",
		"Check scope + variable overwrite (local/global conflict)",
		"Isolate block bằng cách comment từng phần",
		"Verify syntax tree: (), {}, if-end balance",
		"Check nil propagation chain (object bị mất reference từ trước)",
		"Re-run with print checkpoints để trace execution flow"
	}

	return fallback[math.random(1, #fallback)]
end

local function stripStrings(line)
	-- remove "..." and '...'
	line = line:gsub('".-"', '""')
	line = line:gsub("'.-'", "''")
	return line
end

local function isNotLuau(src)
	if not src or src == "" then return true end

	local lines = {}
	for l in src:gmatch("[^\n]+") do
		table.insert(lines, l)
	end

	local luaHints = 0
	local total = #lines

	local luaKeywords = {
		"local","function","end","if","then","return","for","while",
		"game","workspace","Instance","Enum","print"
	}

	for _, line in ipairs(lines) do
		for _, kw in ipairs(luaKeywords) do
			if line:find(kw) then
				luaHints += 1
				break
			end
		end
	end

	-- nếu gần như KHÔNG có syntax Luau
	if total > 3 and luaHints <= 1 then
		return true
	end

	-- detect spam / log dump pattern
	if src:match("LINE %d+") and src:match("Có thể biến") then
		return true
	end

	-- detect random text (no symbols of Lua structure)
	if not src:find("=") and not src:find("function") and not src:find("local") then
		if src:find(" ") and #src > 50 then
			return true
		end
	end

	return false
end

