local function suggest(err)
	local e = tostring(err):lower()

	-- syntax
	if e:find("expected") and e:find("')") then
		return {
			"✔ Kiểm tra xem có thiếu dấu ')'",
			"✔ Nhìn dòng phía trên lỗi (thường là chưa đóng hàm)",
			"✔ Đếm số '(' và ')' xem có bằng nhau không"
		}
	end

	if e:find("expected 'end'") then
		return {
			"✔ Thêm 'end' ở cuối block if/function/for",
			"✔ Kiểm tra xem có quên đóng function không",
			"✔ Dùng format indent để dễ nhìn scope"
		}
	end

	if e:find("attempt to index") then
		return {
			"✔ Biến đang nil → kiểm tra object có tồn tại chưa",
			"✔ Dùng WaitForChild nếu là Roblox instance",
			"✔ Check xem biến có bị override không"
		}
	end

	if e:find("attempt to call") then
		return {
			"✔ Bạn đang gọi thứ không phải function",
			"✔ Kiểm tra biến có bị ghi đè thành string/table không",
			"✔ Debug bằng print(type(var))"
		}
	end

	if e:find("http") then
		return {
			"✔ Link HttpGet sai hoặc không raw",
			"✔ Test link trên browser trước",
			"✔ Đảm bảo GitHub/raw/text endpoint"
		}
	end

	return {
		"✔ Check logic tổng thể",
		"✔ Dùng print debug từng bước",
		"✔ Xem lại dòng gần lỗi nhất"
	}
end

-- ===== AUTO FIX LINE ENGINE =====
local function autoFix(err, lineText)
	local e = tostring(err):lower()

	-- missing ')'
	if e:find("expected") and e:find("')") then
		if not lineText:find("%)") then
			return lineText .. ")"
		end
	end

	-- missing 'end' (basic fallback)
	if e:find("expected 'end'") then
		return lineText .. "\nend"
	end

	-- remove broken trailing comma (basic safe fix)
	if e:find("unexpected symbol") then
		if lineText:sub(-1) == "," then
			return lineText:sub(1, -2)
		end
	end

	-- nil index safe hint (no real fix possible)
	if e:find("attempt to index") then
		return "-- FIX: check nil before use -> " .. lineText
	end

	return "-- NO AUTO FIX AVAILABLE -> " .. lineText
end

