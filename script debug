local function getConclusion(errorCount, fatal, runtimeFail)
	if runtimeFail then
		return "✨ KẾT LUẬN: SCRIPT NÁT, KHÔNG DÙNG ĐƯỢC 💀"
	end

	if fatal >= 3 or errorCount >= 10 then
		return "✨ KẾT LUẬN: SCRIPT VẪN CHẠY ĐƯỢC, NHƯNG KHÔNG ỔN ĐỊNH VÀI CHỖ 😑"
	end

	if errorCount == 0 then
		return "✨ KẾT LUẬN: SCRIPT ỔN HOÀN TOÀN 👍 🎉"
	end

	return "✨ KẾT LUẬN: SCRIPT CÓ VÀI LỖI NHỎ, CẦN SỬA 😐"
end

