table.insert(Connections, RunService.Heartbeat:Connect(function(deltaTime)
    if not Alive or not EntityRoot or not EntityRoot.Parent then 
        if Alive then Cleanup() end
        return 
    end

    -- 1. Logic đổi hướng tự động mỗi 7-10s
    if tick() - LastDirectionChange >= CHANGE_INTERVAL then
        ChooseSafeTarget()
        LastDirectionChange = tick()
        CHANGE_INTERVAL = math.random(7, 10)
    end

    -- 2. Tính toán hướng di chuyển
    local currentPos = EntityRoot.Position
    local targetPosXZ = Vector3.new(CurrentTarget.X, currentPos.Y, CurrentTarget.Z)
    local offset = targetPosXZ - currentPos
    local distance = offset.Magnitude

    if distance <= 2 then
        ChooseSafeTarget()
        return
    end

    MoveDirection = offset.Unit
    
    if FrontBlocked() then
        ChooseSafeTarget()
        return
    end

    -- 3. Di chuyển MƯỢT bằng Lerp
    -- Smoothness: 0.1 (rất mượt/chậm) đến 0.9 (gần như cứng). 0.2 là mức ổn nhất.
    -- Di chuyển đúng tốc độ
-- Di chuyển đúng tốc độ
local newPosition = currentPos + (MoveDirection * MOVE_SPEED * deltaTime)

-- Chỉ Lerp trục Y
local newY = currentPos.Y + (CurrentTarget.Y - currentPos.Y) * math.clamp(deltaTime * 8, 0, 1)

newPosition = Vector3.new(
    newPosition.X,
    newY,
    newPosition.Z
)

-- Quay hướng nhìn mượt
local targetCFrame = CFrame.lookAt(newPosition, newPosition + MoveDirection)

if Entity:IsA("Model") then
    Entity:PivotTo(Entity:GetPivot():Lerp(targetCFrame, 0.2))
else
    Entity.CFrame = Entity.CFrame:Lerp(targetCFrame, 0.2)
end

if EntityHitbox then
	EntityHitbox.CFrame = EntityRoot.CFrame
end

