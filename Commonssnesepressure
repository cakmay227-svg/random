	local function CheckEncounter()
		if child.Name == "SearchlightsEncounter" then
			SearchlightsEncounter = child

			table.insert(Connections, SearchlightsEncounter.DescendantAdded:Connect(function()
				TryReady()
			end))

			TryReady()
		end
	end

	CheckEncounter()

	if child:IsA("Model") then
		table.insert(Connections, child:GetPropertyChangedSignal("Name"):Connect(CheckEncounter))
	end

end))

