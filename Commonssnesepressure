local TouchDebounce = {}

local function HandleTouch(hit)

	if not Alive then
		return
	end

	local character = hit:FindFirstAncestorOfClass("Model")

	if not character then
		return
	end

	local player = Players:GetPlayerFromCharacter(character)

	if not player then
		return
	end

	if TouchDebounce[player] then
		return
	end

	TouchDebounce[player] = true

	task.spawn(function()
		OnTouchPlayer(player)

		task.wait(0.2)

		TouchDebounce[player] = nil
	end)

end

table.insert(Connections, EntityHitbox.Touched:Connect(HandleTouch))

local function GetCurrentRoomModelCount()

	local count = 0

	for _, obj in ipairs(Rooms:GetChildren()) do
		if obj:IsA("Model") then
			count += 1
		end
	end

	return count

end

