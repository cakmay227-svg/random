local InitialRoomModelCount = 0

local function RefreshFloors()
	if not SearchlightsEncounter then
		return false
	end

	table.clear(FloorParts)

	for _, obj in ipairs(SearchlightsEncounter:GetDescendants()) do
		if obj:IsA("BasePart")
		and obj.Name == "Floor"
		and obj.Transparency == 0 then
			table.insert(FloorParts, obj)
		end
	end

	return #FloorParts > 0
end

local function Cleanup()

	if not Alive then
		return
	end

	Alive = false

	for _, connection in ipairs(Connections) do
		connection:Disconnect()
	end

	table.clear(Connections)
	table.clear(FloorParts)

	if Entity then
		Entity:Destroy()
	end

if EntityHitbox then
	EntityHitbox:Destroy()
	EntityHitbox = nil
end

	Entity = nil
	EntityRoot = nil
end

local function GetRandomFloor()

	if #FloorParts == 0 then
		return nil
	end

	return FloorParts[math.random(1, #FloorParts)]

end

local function GetRandomPointOnFloor(floor)
    local size = floor.Size
    local cf = floor.CFrame
    
    local x = (math.random() - 0.5) * size.X * 0.9
    local z = (math.random() - 0.5) * size.Z * 0.9
    
    -- Tính toán vị trí dựa trên CFrame của sàn để giữ độ cao Y chính xác
    local point = (cf * CFrame.new(x, size.Y/2 + HEIGHT_OFFSET, z)).Position
    return point
end

local function SetEntityPosition(position)

	if not Alive then
		return
	end

	if Entity:IsA("Model") then

		Entity:PivotTo(
			CFrame.new(position)
		)

	else

		Entity.Position = position

	end

end

local function TryReady()
	if Ready then
		return
	end

	if not SearchlightsEncounter then
		return
	end

	if not EntityNodesFolder then
		EntityNodesFolder = SearchlightsEncounter:FindFirstChild("EntityNodes")
		if not EntityNodesFolder then
			return
		end
	end

	RefreshFloors()

	if #FloorParts == 0 then
		return
	end

	local nodes = {}
	local exitPart

	for _, obj in ipairs(EntityNodesFolder:GetDescendants()) do
		if obj:IsA("BasePart") then
			if obj.Name == "Node" then
				table.insert(nodes, obj)
			elseif obj.Name == "Exit" and not exitPart then
				exitPart = obj
			end
		end
	end

	if #nodes > 0 then
		SpawnPosition = nodes[math.random(#nodes)].Position
	elseif exitPart then
		SpawnPosition = exitPart.Position
	else
		return
	end

	Ready = true
end

TryReady()

if not Ready then

