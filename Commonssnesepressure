end
end))

local FORWARD_CHECK_DISTANCE = 8
local FLOOR_CHECK_DISTANCE = 10

local RayParams = RaycastParams.new()
RayParams.FilterType = Enum.RaycastFilterType.Exclude
RayParams.FilterDescendantsInstances = {Entity}
RayParams.IgnoreWater = true

local function IsPositionOnFloor(position)

	local result = Workspace:Raycast(
		position + Vector3.new(0, 5, 0),
		Vector3.new(0, -30, 0),
		RayParams
	)

	if not result then
		return false
	end

	local hit = result.Instance

	return hit
		and hit:IsA("BasePart")
		and hit.Name == "Floor"
		and hit.Transparency == 0

end

FrontBlocked = function()

	local origin = EntityRoot.Position

	local direction = MoveDirection

	if direction.Magnitude <= 0 then
		return true
	end

	local wallHit = Workspace:Raycast(
		origin,
		direction * FORWARD_CHECK_DISTANCE,
		RayParams
	)

	if wallHit then

		local hit = wallHit.Instance

		if not (hit.Name == "Floor" and hit.Transparency > 0.1) then
			return true
		end

	end

	local frontPos =
		origin + direction * FLOOR_CHECK_DISTANCE

	if not IsPositionOnFloor(frontPos) then
		return true
	end

	return false

end

ChooseSafeTarget = function()
    for i = 1, 30 do
        local floor = GetRandomFloor()
        if floor then
            local point = GetRandomPointOnFloor(floor)
            -- Kiểm tra xem điểm này có hợp lệ không
            if IsPositionOnFloor(point) then
                CurrentTarget = point
                CurrentFloor = floor
                return
            end
        end
    end
    Cleanup()
end

