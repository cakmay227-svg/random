	end
end

	if SearchlightsEncounter then
		table.insert(Connections, SearchlightsEncounter.DescendantAdded:Connect(function()
			TryReady()
		end))

		TryReady()
	end

	repeat
		RunService.Heartbeat:Wait()
	until Ready
end

