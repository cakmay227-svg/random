local RadiusMin = 15
local RadiusMax = 20

local Angle = math.rad(math.random(0, 359))
local Radius = math.random(RadiusMin, RadiusMax)

local Offset = Vector3.new(
	math.cos(Angle) * Radius,
	3.5,
	math.sin(Angle) * Radius
)

local Pos = HRP.Position + Offset

local WallDistance = 7

local Params = RaycastParams.new()
Params.FilterType = Enum.RaycastFilterType.Blacklist
Params.FilterDescendantsInstances = {Obj, Char}

for _,Dir in ipairs({
	Vector3.xAxis,
	-Vector3.xAxis,
	Vector3.zAxis,
	-Vector3.zAxis
}) do
	local Result = workspace:Raycast(Pos, Dir * WallDistance, Params)

	if Result then
		local Dist = (Result.Position - Pos).Magnitude
		Pos -= Dir * (WallDistance - Dist)
	end
end

