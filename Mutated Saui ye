function GitAud(filename)
	return (getcustomasset or getsynasset)(filename)
end

function CustomGitSound(filename, volume, _, soundName, parent, looped)
	local sound = Instance.new("Sound")

	sound.SoundId = GitAud(filename)
	sound.Parent = parent or workspace
	sound.Volume = volume or 1
	sound.PlaybackSpeed = 0.9
	sound.Name = soundName or "bgtheme"
	sound.Looped = looped or false

	local sfx = Instance.new("DistortionSoundEffect")
	sfx.Parent = sound

	return sound
end

