local function applyReverb(sound)
	if processed[sound] then return end
	if not sound:IsA("Sound") then return end

	-- trÃ¡nh add trÃ¹ng
	if sound:FindFirstChildOfClass("ReverbSoundEffect") then
		processed[sound] = true
		return
	end

	local reverb = Instance.new("ReverbSoundEffect")
	reverb.DecayTime = DECAY_TIME
	reverb.Density = 1
	reverb.Diffusion = 1
	reverb.WetLevel = 0 -- cÃ³ thá»ƒ chá»‰nh xuá»‘ng -5, -10 náº¿u muá»‘n nháº¹ hÆ¡n
	reverb.DryLevel = 0
	reverb.Parent = sound

	-- preset (Roblox tá»± xá»­ lÃ½ profile)
	pcall(function()
		reverb.ReverbType = REVERB_PRESET
	end)

	processed[sound] = true
end

