local TweenRunning = false

_G.SetHauntPercent = function(value)
	value = math.clamp(tonumber(value) or 0, 0, 100)

	if TweenRunning then
		return
	end

	TweenRunning = true

	task.spawn(function()

		while math.abs(Percent - value) > 0 do

			if Percent < value then
				Percent += math.min(3, value - Percent)
			else
				Percent -= math.min(3, Percent - value)
			end

			SetPercent(Percent)
			updateEffects()

			Glow.Thickness = 1.5 + (Percent / 100) * 4

			task.wait(0.02)
		end

		if Percent >= 100 and not EndingStarted then
			EndingStarted = true
			endingSequence()
		end

		TweenRunning = false
	end)
end

