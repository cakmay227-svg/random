local function createWarningUI()
	if warningGui then return end

	warningGui = Instance.new("ScreenGui")
	warningGui.Name = "EntityWarningUI"
	warningGui.ResetOnSpawn = false
	warningGui.Parent = playerGui

	warningLabel = Instance.new("TextLabel")
	warningLabel.Size = UDim2.new(0, 400, 0, 50)
	warningLabel.Position = UDim2.new(0.5, -200, 0.85, 0)
	warningLabel.BackgroundTransparency = 1
	warningLabel.Text = ""
	warningLabel.TextScaled = true
	warningLabel.Font = Enum.Font.GothamBlack
	warningLabel.Parent = warningGui

	--  gradient tím + hng
	local grad = Instance.new("UIGradient")
	grad.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(180, 0, 255)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 170))
	})
	grad.Parent = warningLabel
end

local function glitchText()
	if not warningLabel then return end

	task.spawn(function()
		while warningLabel and warningLabel.Parent do
			local base = "!!! ENTITY DETECTED !!!"

			-- glitch random ký t
			local glitched = ""
			for i = 1, #base do
				local c = base:sub(i,i)
				if math.random(1, 6) == 1 then
					c = string.char(math.random(33, 126))
				end
				glitched ..= c
			end

			warningLabel.Text = glitched
			warningLabel.Rotation = math.random(-3, 3)
			warningLabel.TextTransparency = math.random(0, 2) * 0.1

			task.wait(1)
		end
	end)
end

local function playWarningSounds()
	local s1 = Instance.new("Sound", workspace)
	s1.SoundId = "rbxassetid://101323363019758" -- m thay
	s1.Volume = 1
	s1:Play()

	local s2 = Instance.new("Sound", workspace)
	s2.SoundId = "rbxassetid://126100882513980" -- ambience
	s2.Looped = true
	s2.Volume = 0.6
	s2:Play()

	table.insert(warningSounds, s1)
	table.insert(warningSounds, s2)
end

local function stopWarningSystem()
	if warningConn then
		warningConn:Disconnect()
		warningConn = nil
	end

	if warningGui then
		warningGui:Destroy()
		warningGui = nil
		warningLabel = nil
	end

	for _, s in ipairs(warningSounds) do
		if s then
			s:Stop()
			s:Destroy()
		end
	end

	warningSounds = {}

	if warningGui then
		warningGui:SetAttribute("Active", false)
	end
end

local function startEntityLoop()
	if warningConn then return end

	warningConn = RunService.Heartbeat:Connect(function()
		local entityType = nil

		for _, obj in ipairs(Workspace:GetDescendants()) do
			if obj:IsA("Model") then
				if obj.Name == "RushMoving" then
					entityType = "RUSH"
					break
				elseif obj.Name == "AmbushMoving" then
					entityType = "AMBUSH"
					break
				end
			end
		end

		if entityType then
			createWarningUI()

			-- set text theo entity
			if entityType == "RUSH" then
				warningLabel.Text = "RUSH IS COMING"
			elseif entityType == "AMBUSH" then
				warningLabel.Text = "AMBUSH IS COMING"
			end

			-- ch chy glitch + sound 1 ln
			if not warningGui:GetAttribute("Active") then
				warningGui:SetAttribute("Active", true)
				glitchText()
				playWarningSounds()
			end

		else
			-- cleanup khi không còn entity
			if warningGui then
				warningGui:Destroy()
				warningGui = nil
				warningLabel = nil
			end

			for _, s in ipairs(warningSounds) do
				if s then s:Destroy() end
			end
			warningSounds = {}
		end
	end)
end

