-- FIX + CLEAN MODEL
local function sanitizeModel(model)
	if not model:IsA("Model") then return end

	for _, v in ipairs(model:GetDescendants()) do

		workspace["viridis pentagram"].StarCenter.ItemHolder.Item.Enabled = true
		workspace["viridis pentagram"].StarCenter.ItemHolder.Item.Texture = "rbxassetid://72724972461305" 

		-- ❌ xóa BeamFlat / BeamGlow
		if v:IsA("Beam") and (v.Name == "BeamFlat" or v.Name == "BeamGlow") then
			v:Destroy()
		end

		-- 🔧 fix parts
		if v:IsA("BasePart") then
			v.Anchored = true
			v.CanCollide = false
		end
		
		-- 🟢 đổi mọi màu sang xanh lá nhưng giữ nguyên độ sáng
local function shiftToGreen(color)
	local h, s, v = color:ToHSV()

	-- Hue xanh lá ≈ 120° = 0.333
	return Color3.fromHSV(0.333, s, v)
end

if v:IsA("BasePart") then
	v.Color = shiftToGreen(v.Color)
end

if v:IsA("ParticleEmitter") then
	local seq = v.Color
	local newKPs = {}

	for _, kp in ipairs(seq.Keypoints) do
		table.insert(newKPs, ColorSequenceKeypoint.new(
			kp.Time,
			shiftToGreen(kp.Value)
		))
	end

	v.Color = ColorSequence.new(newKPs)
end

if v:IsA("Beam") or v:IsA("Trail") then
	local seq = v.Color
	local newKPs = {}

	for _, kp in ipairs(seq.Keypoints) do
		table.insert(newKPs, ColorSequenceKeypoint.new(
			kp.Time,
			shiftToGreen(kp.Value)
		))
	end

	v.Color = ColorSequence.new(newKPs)
end

if v:IsA("PointLight")
	or v:IsA("SpotLight")
	or v:IsA("SurfaceLight") then
	v.Color = shiftToGreen(v.Color)
end

		-- 🔥 chỉnh prompt + connect trigger
