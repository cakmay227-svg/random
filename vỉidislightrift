local particleOut = parentModel:FindFirstChild("ParticlesOut", true)

for _, obj in ipairs(parentModel:GetDescendants()) do
	if particleOut and obj:IsDescendantOf(particleOut) then
		continue
	end

	if obj:IsA("BasePart") then
		obj.Transparency = 1
		obj.CanCollide = false
	end

	if obj:IsA("PointLight") or obj:IsA("SpotLight") or obj:IsA("SurfaceLight") then
		obj.Enabled = false
	end

	if obj:IsA("ParticleEmitter") then
		obj.Enabled = false
	end

	if obj:IsA("Beam") or obj:IsA("Trail") then
		obj.Enabled = false
	end
end

				local maxLifetime = 0

				if particleOut then
					for _, pe in ipairs(particleOut:GetDescendants()) do
						if pe:IsA("ParticleEmitter") then
							-- play 1 lần
							local emitCount = pe:GetAttribute("BurstAmount") or 30
							pe:Emit(emitCount)
							pe.Enabled = false

							-- tính thời gian sống để wait
							local life = pe.Lifetime
							local t = life.Max
							if t > maxLifetime then
								maxLifetime = t
							end
						end
					end
				end

				-- đợi particle xong rồi destroy model
				task.delay(maxLifetime + 0.2, function()
					if parentModel and parentModel.Parent then
						parentModel:Destroy()
					end
				end)
			end)
		end
	end

	-- set PrimaryPart
	local pp = model:FindFirstChildWhichIsA("BasePart", true)
	if pp then
		model.PrimaryPart = pp
	end

	model:PivotTo(model:GetPivot())
