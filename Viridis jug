local function createHighlight(inst)
	local h = Instance.new("Highlight")
	h.FillColor = Color3.fromRGB(120, 255, 160)
	h.OutlineColor = Color3.fromRGB(80, 255, 120)
	h.FillTransparency = 0.4
	h.OutlineTransparency = 0
	h.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	h.Parent = inst

	table.insert(activeHighlights, h)
end

local function process(inst)
	if stopped then return end

	-- ðŸšª Door (MODEL only, exact name)
	if inst:IsA("Model") and inst.Name == "Door" then
		if not inst:FindFirstChildOfClass("Highlight") then
			local h = Instance.new("Highlight")
			h.FillColor = Color3.fromRGB(120, 255, 160)
			h.OutlineColor = Color3.fromRGB(80, 255, 120)
			h.FillTransparency = 0.4
			h.OutlineTransparency = 0
