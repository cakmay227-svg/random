local function stopHighlights()
	stopped = true

	-- disconnect event
	if conn then
		conn:Disconnect()
	end

	-- destroy all highlights
	for _, h in ipairs(activeHighlights) do
		if h and h.Parent then
			h:Destroy()
		end
	end

	activeHighlights = {}
end

