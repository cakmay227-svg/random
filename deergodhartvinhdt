function ShowGlitchText(Text)
	local Gui = Instance.new("ScreenGui")
	Gui.IgnoreGuiInset = true
	Gui.ResetOnSpawn = false
	Gui.DisplayOrder = 999999
	Gui.Parent = PlayerGui

	local Label = Instance.new("TextLabel")
	Label.AnchorPoint = Vector2.new(0.5, 0.5)
	Label.Position = UDim2.fromScale(0.5, 0.5)
	Label.Size = UDim2.fromOffset(1200, 200)
	Label.BackgroundTransparency = 1
	Label.Text = Text
	Label.Font = Enum.Font.Code -- font mỏng
	Label.TextScaled = true
	Label.TextColor3 = Color3.fromRGB(170, 70, 255)
	Label.TextStrokeTransparency = 1
	Label.TextTransparency = 0
	Label.Rotation = 0
	Label.Parent = Gui

	local oldBrightness = Color.Brightness
	local oldContrast = Color.Contrast
	local oldSaturation = Color.Saturation
	local oldTint = Color.TintColor

	Color.Enabled = true
	Color.TintColor = Color3.fromRGB(180, 60, 255)
	Color.Brightness = 0.12
	Color.Contrast = 0.3
	Color.Saturation = -0.15

	local Start = tick()

	local Shake
	Shake = RunService.RenderStepped:Connect(function()
		local t = tick() - Start

		if t >= 0.5 then
			Shake:Disconnect()

			TweenService:Create(Color, TweenInfo.new(0.2), {
				Brightness = oldBrightness,
				Contrast = oldContrast,
				Saturation = oldSaturation,
				TintColor = oldTint
			}):Play()

			task.delay(0.2, function()
				Color.Enabled = false
			end)

			Gui:Destroy()
			return
		end

		Label.Position = UDim2.fromScale(
			0.5 + math.random(-20,20)/1000,
			0.5 + math.random(-20,20)/1000
		)

		Label.Rotation = math.random(-35,35)

		Label.TextTransparency = math.random(0,25)/100
	end)
end

