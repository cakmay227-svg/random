local TweenService = game:GetService("TweenService")
local Camera = workspace.CurrentCamera

local originalFOV = Camera.FieldOfView

local Enabled = false
local LoopThread

function GitAud(soundgit, filename)
    local url = soundgit
    local FileName = filename

    writefile(FileName .. ".mp3", game:HttpGet(url))
    return (getcustomasset or getsynasset)(FileName .. ".mp3")
end

function CustomGitSound(soundlink, volume, filename, soundName, parent, looped)
    local sound = Instance.new("Sound")

    sound.SoundId = GitAud(soundlink, filename)
    sound.Parent = parent or workspace
    sound.Volume = volume or 1
    sound.RollOffMaxDistance = 400
    sound.RollOffMinDistance = 5
    sound.PlaybackSpeed = 1
    sound.Name = soundName or "bgtheme"
    sound.Looped = looped or false

    sound:Play()

    return sound
end

local function StartFOVEffect()
	if Enabled then return end
	Enabled = true

	LoopThread = task.spawn(function()
		while Enabled do
			Camera.FieldOfView = 45

			local tween = TweenService:Create(
				Camera,
				TweenInfo.new(
					1,
					Enum.EasingStyle.Quint,
					Enum.EasingDirection.Out
				),
				{
					FieldOfView = originalFOV
				}
			)

			tween:Play()
			task.wait(1)
		end
	end)
end

local function StopFOVEffect()
	Enabled = false
	Camera.FieldOfView = originalFOV
end

local TweenService = game:GetService("TweenService")
local Lighting = game:GetService("Lighting")

local blur = Lighting:FindFirstChild("LoopBlur") or Instance.new("BlurEffect")
blur.Name = "LoopBlur"
blur.Size = 0
blur.Parent = Lighting

local Blur = false
local Thread

local function StartBlurLoop()
	if Blur then return end
	Blur = true

	Thread = task.spawn(function()
		while Blur do
			TweenService:Create(blur, TweenInfo.new(2, Enum.EasingStyle.Linear), {
				Size = 24 -- độ mờ
			}):Play()

			task.wait(2)

			TweenService:Create(blur, TweenInfo.new(2, Enum.EasingStyle.Linear), {
				Size = 0
			}):Play()

			task.wait(2)
		end
	end)
end

local function StopBlurLoop()
	Blur = false

	TweenService:Create(blur, TweenInfo.new(2, Enum.EasingStyle.Linear), {
		Size = 0
	}):Play()
end

