local function StartEntity(data)
    local url, minTime, maxTime, offset = unpack(data)
    
    coroutine.wrap(function()
        local lastSpawnTime = GetPreciseServerTime()
        local BaseSeed = 0
        for i = 1, #game.JobId do BaseSeed += game.JobId:byte(i) end
        local rng = Random.new(BaseSeed + offset)

        while true do
            local nextInterval = rng:NextInteger(minTime, maxTime)
            local targetTime = lastSpawnTime + nextInterval
            
            while GetPreciseServerTime() < targetTime do
                local remaining = targetTime - GetPreciseServerTime()
                if remaining > 0.1 then
                    task.wait(0.05)
                else
                    task.wait() 
                end
            end
           
            local GameData = game:GetService("ReplicatedStorage"):FindFirstChild("GameData")
            local LatestRoom = GameData and GameData:FindFirstChild("LatestRoom")
            
            if not LatestRoom or LatestRoom.Value > 0 then
                local success, err = pcall(function()
                    loadstring(game:HttpGet(url))()
                end)
                
                if success then
                    lastSpawnTime = targetTime 
                else
                    warn("[Elite Sync] Load Error: " .. tostring(err))
                    task.wait(5)
                    lastSpawnTime = GetPreciseServerTime()
                end
            else
                lastSpawnTime = GetPreciseServerTime()
                task.wait(1)
            end
        end
    end)()
end

for _, entityData in pairs(EntityList) do
    StartEntity(entityData)
end
