local player = Players.LocalPlayer

local TOOL_TEXTURES = {
	["Viridislight Bottle"] = "rbxassetid://79634613812234",
	["Viridislight Jug"] = "rbxassetid://76643684989182", 
	["Viridislight Vial"] = "rbxassetid://83697244024585", 
	["spiralRiftCandle"] = "rbxassetid://103455405358047"
}

local function purpleKeepBrightness(color)
	local _, s, v = Color3.toHSV(color)
	return Color3.fromHSV(0.78, s, v) -- Giữ lại 's' và 'v' thay vì đặt cứng bằng 1
end

local function getParticlesOut(model)
	for _, v in ipairs(model:GetDescendants()) do
		if v.Name == "ParticlesOut" then
			return v
		end
	end
	return nil
end

local function updateMutateEffects(model)
	local hasTool = model:GetAttribute("StoredTool") ~= ""

	for _, v in ipairs(model:GetDescendants()) do
		if v:IsA("ParticleEmitter")
		and (v.Name == "MutateEffect" or v.Name == "Mutated") then
			v.Enabled = hasTool
		end
	end
end

local function playParticlesOnce(folder)
	if not folder then return 0 end

	local longest = 0

	for _, v in ipairs(folder:GetDescendants()) do
		if v:IsA("ParticleEmitter") then
			v.Enabled = false

			local amount = v:GetAttribute("EmitCount") or 20
			v:Emit(amount)

			local t =
				v.Lifetime.Max +
				(v:GetAttribute("EmitDelay") or 0)

			if t > longest then
				longest = t
			end
		end
	end

	return longest
end

local function getEquippedTool()
	local char = player.Character
	if not char then return nil end

	for _, obj in ipairs(char:GetChildren()) do
		if obj:IsA("Tool") then
			return obj
		end
	end
	return nil
end

