-- FIX + CLEAN MODEL
local function sanitizeModel(model)
	if not model:IsA("Model") then return end

	for _, v in ipairs(model:GetDescendants()) do

		if v:IsA("Beam") and (v.Name == "BeamFlat" or v.Name == "BeamGlow") then
			v:Destroy()
		end

		if v:IsA("BasePart") then
			v.Anchored = true
			v.CanCollide = false
		end

		-- màu tím
		local function shiftToPurple(color)
			local h, s, v = color:ToHSV()
			return Color3.fromHSV(270/360, s, v)
		end

		if v:IsA("BasePart") then
			v.Color = shiftToPurple(v.Color)
		elseif v:IsA("PointLight") or v:IsA("SpotLight") or v:IsA("SurfaceLight") then
			v.Color = shiftToPurple(v.Color)
		elseif v:IsA("ParticleEmitter") then
			local seq = v.Color
			local newKPs = {}

			for _, kp in ipairs(seq.Keypoints) do
				table.insert(newKPs, ColorSequenceKeypoint.new(kp.Time, shiftToPurple(kp.Value)))
			end

			v.Color = ColorSequence.new(newKPs)
		elseif v:IsA("Beam") or v:IsA("Trail") then
			local seq = v.Color
			local newKPs = {}

			for _, kp in ipairs(seq.Keypoints) do
				table.insert(newKPs, ColorSequenceKeypoint.new(kp.Time, shiftToPurple(kp.Value)))
			end

			v.Color = ColorSequence.new(newKPs)
		end

		-- PROMPT ONLY
		if v:IsA("ProximityPrompt") then
			v.HoldDuration = 3
			v.MaxActivationDistance = 5
			v.Style = Enum.ProximityPromptStyle.Custom
			v:SetAttribute("CustomFrame", "Black")

			handlePrompt(model, v) -- 👈 QUAN TRỌNG NHẤT
		end
	end

	local pp = model:FindFirstChildWhichIsA("BasePart", true)
	if pp then model.PrimaryPart = pp end

	model:PivotTo(model:GetPivot())
end

